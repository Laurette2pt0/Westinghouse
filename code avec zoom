def init_database():
    conn = sqlite3.connect('camvis_data.db')
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date TEXT NOT NULL,
            id_camera TEXT,
            chemin_image TEXT,
            ratio_px_mm REAL,
            nb_mesures INTEGER
        )
    ''')
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS mesures (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            session_id INTEGER,
            num_mesure INTEGER,
            centre_x REAL,
            centre_y REAL,
            diametre_px REAL,
            diametre_mm REAL,
            type_mesure TEXT
        )
    ''')
    conn.commit()
    conn.close()

def sauvegarder_session():
    if not cercles:
        dpg.set_value("statut", "Aucune mesure a sauvegarder")
        return
    conn = sqlite3.connect('camvis_data.db')
    cursor = conn.cursor()
    id_camera = dpg.get_value("id_camera") if dpg.does_item_exist("id_camera") else ID_CAMERA_PAR_DEFAUT
    if not id_camera:
        id_camera = ID_CAMERA_PAR_DEFAUT
    date_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    cursor.execute('INSERT INTO sessions (date, id_camera, chemin_image, ratio_px_mm, nb_mesures) VALUES (?, ?, ?, ?, ?)',
                   (date_str, id_camera, chemin_image_actuelle, ratio_px_mm, len(cercles)))
    session_id = cursor.lastrowid
    for i, (cx, cy, r) in enumerate(cercles):
        d_px = r * 2
        d_mm = d_px / ratio_px_mm if ratio_px_mm else None
        type_mesure = "Etalon" if i == cercle_etalon_idx else "Mesure"
        cursor.execute('INSERT INTO mesures (session_id, num_mesure, centre_x, centre_y, diametre_px, diametre_mm, type_mesure) VALUES (?, ?, ?, ?, ?, ?, ?)',
                       (session_id, i+1, cx, cy, d_px, d_mm, type_mesure))
    conn.commit()
    conn.close()
    dpg.set_value("statut", f"Session sauvegardee : {len(cercles)} mesures")
    charger_historique()

def charger_historique():
    conn = sqlite3.connect('camvis_data.db')
    cursor = conn.cursor()
    cursor.execute('SELECT * FROM sessions ORDER BY date DESC')
    sessions = cursor.fetchall()
    conn.close()
    if not dpg.does_item_exist("table_historique"):
        return
    dpg.delete_item("table_historique", children_only=True)
    dpg.add_table_column(label="ID",     parent="table_historique", width_fixed=True, init_width_or_weight=30)
    dpg.add_table_column(label="Date",   parent="table_historique", width_fixed=True, init_width_or_weight=130)
    dpg.add_table_column(label="Camera", parent="table_historique", width_fixed=True, init_width_or_weight=80)
    dpg.add_table_column(label="N",      parent="table_historique", width_fixed=True, init_width_or_weight=35)
    for s in sessions:
        with dpg.table_row(parent="table_historique"):
            dpg.add_text(str(s[0]))
            dpg.add_text(s[1][:16] if s[1] else "")
            dpg.add_text(s[2] if s[2] else "")
            dpg.add_text(str(s[5]) if s[5] else "0")

