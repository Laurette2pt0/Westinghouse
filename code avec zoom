def definir_etalon():
    global ratio_px_mm, cercle_etalon_idx
    if not cercles:
        dpg.set_value("statut", "Dessinez d'abord un cercle sur le trou etalon !")
        return
    idx = len(cercles) - 1
    cx, cy, r = cercles[idx]
    d_px = r * 2
    ratio_px_mm = d_px / DIAMETRE_ETALON_MM
    cercle_etalon_idx = idx
    dpg.set_value("label_kp", f"Kp = {ratio_px_mm:.4f} px/mm")
    dpg.set_value("statut", f"Calibration OK — etalon = {int(d_px)} px  Kp = {ratio_px_mm:.4f} px/mm")
    update_display()

def reset_calibration():
    global ratio_px_mm, cercle_etalon_idx
    ratio_px_mm = None
    cercle_etalon_idx = None
    dpg.set_value("label_kp", "Kp = non calibre")
    dpg.set_value("statut", "Calibration reinitialisee")
    update_display()

# ─────────────────────────────────────────
# GESTION SOURIS — ZOOM + PAN + DESSIN
# ─────────────────────────────────────────
def on_mouse_wheel(sender, app_data):
    """app_data > 0 = zoom in, < 0 = zoom out."""
    global zoom_level, offset_x, offset_y
    if not dpg.is_item_hovered("drawlist_principal"):
        return
    if img_originale is None:
        return

    delta = app_data  # +1 ou -1 selon la molette
    mx, my = dpg.get_drawing_mouse_pos()

    # coordonnée image sous le curseur AVANT zoom
    img_x_before = (mx - offset_x) / zoom_level
    img_y_before = (my - offset_y) / zoom_level

    # nouveau zoom
    if delta > 0:
        nouveau_zoom = min(zoom_level * (1 + ZOOM_STEP), ZOOM_MAX)
    else:
        nouveau_zoom = max(zoom_level / (1 + ZOOM_STEP), ZOOM_MIN)

    zoom_level = nouveau_zoom

    # recalculer l'offset pour que la coordonnée image reste sous le curseur
    offset_x = mx - img_x_before * zoom_level
    offset_y = my - img_y_before * zoom_level

    clamp_offsets()
    rebuild_texture_zoom()
    update_display()

def on_mouse_click(sender, app_data):
    """app_data = bouton (0=gauche, 1=droit, 2=milieu)."""
    global point1_temp, cercles, pan_actif, pan_last_x, pan_last_y

    if not dpg.is_item_hovered("drawlist_principal"):
        return

    mx, my = dpg.get_drawing_mouse_pos()

    # ── CLIC SUR MINIMAP (bouton gauche, hors mode dessin) ──
    if img_originale is not None and app_data == 0:
        mini_h = int(MINI_W * img_originale.shape[0] / img_originale.shape[1])
        if MINI_X <= mx <= MINI_X + MINI_W and MINI_Y <= my <= MINI_Y + mini_h:
            # centrer la vue sur ce point de l'image
            rel_x = (mx - MINI_X) / MINI_W
            rel_y = (my - MINI_Y) / mini_h
            img_cx = rel_x * img_originale.shape[1]
            img_cy = rel_y * img_originale.shape[0]
            global offset_x, offset_y
            offset_x = W / 2 - img_cx * zoom_level
            offset_y = H / 2 - img_cy * zoom_level
            clamp_offsets()
            rebuild_texture_zoom()
            update_display()
            return

    # ── DESSIN (bouton gauche) ──
    if app_data == 0 and mode_dessin:
        if not (0 <= mx <= W and 0 <= my <= H):
            return
        # convertir en coordonnées image
        ix, iy = screen_to_image(mx, my)

        if point1_temp is None:
            point1_temp = (ix, iy)
            update_display()
            dpg.set_value("statut", f"Point 1 ({int(ix)}, {int(iy)}) — Clic 2 : bord oppose")
        else:
            x1, y1 = point1_temp
            cx_img = (x1 + ix) / 2
            cy_img = (y1 + iy) / 2
            radius = math.sqrt((ix - x1)**2 + (iy - y1)**2) / 2
            if radius > 5:
                cercles.append((cx_img, cy_img, radius))
                if ratio_px_mm:
                    dpg.set_value("statut", f"Cercle ajoute — O = {(radius*2)/ratio_px_mm:.2f} mm")
                else:
                    dpg.set_value("statut", f"Cercle ajoute — {int(radius*2)} px")
            else:
                dpg.set_value("statut", "Les 2 points sont trop proches, recommencez")
            point1_temp = None
            update_display()

def on_mouse_down(sender, app_data):
    """Début du pan (clic droit maintenu)."""
    global pan_actif, pan_last_x, pan_last_y
    if app_data == 1 and dpg.is_item_hovered("drawlist_principal"):  # bouton droit
        pan_actif = True
        mx, my = dpg.get_mouse_pos()
        pan_last_x = mx
        pan_last_y = my

def on_mouse_release(sender, app_data):
    """Fin du pan."""
    global pan_actif
    if app_data == 1:
        pan_actif = False

def on_mouse_move(sender, app_data):
    global pan_last_x, pan_last_y, offset_x, offset_y

    # ── PAN ──
    if pan_actif and img_originale is not None:
        mx, my = dpg.get_mouse_pos()
        dx = mx - pan_last_x
        dy = my - pan_last_y
        offset_x += dx
        offset_y += dy
        pan_last_x = mx
        pan_last_y = my
        clamp_offsets()
        rebuild_texture_zoom()
        update_display()
        return

    # ── PREVIEW DESSIN ──
    if not mode_dessin or point1_temp is None:
        return
    if not dpg.is_item_hovered("drawlist_principal"):
        return

    mx_draw, my_draw = dpg.get_drawing_mouse_pos()
    if not (0 <= mx_draw <= W and 0 <= my_draw <= H):
        return

    x1_img, y1_img = point1_temp
    ix, iy = screen_to_image(mx_draw, my_draw)

    sx1, sy1 = image_to_screen(x1_img, y1_img)
    radius_screen = math.sqrt((mx_draw - sx1)**2 + (my_draw - sy1)**2) / 2
    cx_s = (sx1 + mx_draw) / 2
    cy_s = (sy1 + my_draw) / 2

    update_display()
    dpg.draw_line((sx1, sy1), (mx_draw, my_draw),
                  color=(0, 200, 255, 180), thickness=1, parent="drawlist_principal")
    dpg.draw_circle((cx_s, cy_s), radius_screen,
                    color=(0, 200, 255, 200), thickness=2, parent="drawlist_principal")
    dpg.draw_circle((cx_s, cy_s), 4, color=(255,255,255,255),
                    fill=(255,255,255,200), parent="drawlist_principal")
    dpg.draw_circle((mx_draw, my_draw), 6,
                    color=(0, 200, 255, 255), fill=(0, 200, 255, 180), parent="drawlist_principal")

    r_img = math.sqrt((ix - x1_img)**2 + (iy - y1_img)**2) / 2
    if ratio_px_mm and r_img > 0:
        dpg.set_value("statut", f"O = {(r_img*2)/ratio_px_mm:.2f} mm")
    elif r_img > 0:
        dpg.set_value("statut", f"O = {int(r_img*2)} px")

def reset_zoom():
    """Bouton pour revenir au zoom 1:1."""
    global zoom_level, offset_x, offset_y
    zoom_level = 1.0
    offset_x   = 0.0
    offset_y   = 0.0
    if img_originale is not None:
        rebuild_texture_zoom()
    update_display()
    dpg.set_value("statut", "Zoom reinitialise")

def clear_cercles():
    global cercles, point1_temp, ratio_px_mm, cercle_etalon_idx
    cercles = []
    point1_temp = None
    ratio_px_mm = None
    cercle_etalon_idx = None
    dpg.set_value("label_kp", "Kp = non calibre")
    update_display()
    dpg.set_value("statut", "Cercles effaces — calibration reinitialisee")

def supprimer_dernier():
    global cercles, cercle_etalon_idx, ratio_px_mm
    if cercles:
        idx = len(cercles) - 1
        cercles.pop()
        if cercle_etalon_idx == idx:
            cercle_etalon_idx = None
            ratio_px_mm = None
            dpg.set_value("label_kp", "Kp = non calibre")
            dpg.set_value("statut", "Cercle etalon supprime : recalibrez")
        else:
            dpg.set_value("statut", "Dernier cercle supprime")
        update_display()

