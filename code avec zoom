# VARIABLES GLOBALES
# ─────────────────────────────────────────
chemin_image_actuelle = None
texture_tag = None
cercles = []
mode_dessin = False
point1_temp = None

# CALIBRATION
DIAMETRE_ETALON_MM = 60.0
ratio_px_mm = None
cercle_etalon_idx = None

# ID CAMERA par defaut
ID_CAMERA_PAR_DEFAUT = "CAM-001"

# DIMENSIONS IMAGE (canvas de dessin)
W = 1630
H = 970

# ─────────────────────────────────────────
# ZOOM & PAN — nouvelles variables
# ─────────────────────────────────────────
zoom_level    = 1.0
ZOOM_MIN      = 0.2
ZOOM_MAX      = 10.0
ZOOM_STEP     = 0.15          # facteur multiplicatif par cran de molette

offset_x      = 0.0           # décalage X de la vue (pixels image)
offset_y      = 0.0           # décalage Y de la vue (pixels image)

pan_actif     = False         # clic droit maintenu
pan_last_x    = 0.0
pan_last_y    = 0.0

# MINIMAP
MINI_W        = 260           # largeur de la minimap (px)
MINI_H        = 0             # calculée dynamiquement selon H/W
MINI_X        = W - MINI_W - 10  # position dans le drawlist
MINI_Y        = 10

# image originale conservée pour le zoom
img_originale = None          # np.ndarray RGBA float32 pleine résolution

# ─────────────────────────────────────────
# HELPERS ZOOM
# ─────────────────────────────────────────
def screen_to_image(sx, sy):
    """Convertit des coordonnées écran (drawlist) en coordonnées image."""
    ix = (sx - offset_x) / zoom_level
    iy = (sy - offset_y) / zoom_level
    return ix, iy

def image_to_screen(ix, iy):
    """Convertit des coordonnées image en coordonnées écran (drawlist)."""
    sx = ix * zoom_level + offset_x
    sy = iy * zoom_level + offset_y
    return sx, sy

def clamp_offsets():
    """Empêche de sortir de l'image."""
    global offset_x, offset_y
    # largeur/hauteur de l'image affichée à ce zoom
    iw = W * zoom_level
    ih = H * zoom_level
    # on ne peut pas aller plus loin que le bord droit / bas
    offset_x = max(min(offset_x, 0), W - iw)
    offset_y = max(min(offset_y, 0), H - ih)

def rebuild_texture_zoom():
    """Recrée la texture à partir de l'image originale avec le zoom courant."""
    global texture_tag
    if img_originale is None:
        return

    # région de l'image originale visible à l'écran
    # offset_x/y sont négatifs quand on a zoomé et scrollé
    src_x = int(-offset_x / zoom_level)
    src_y = int(-offset_y / zoom_level)
    src_w = int(W / zoom_level)
    src_h = int(H / zoom_level)

    # clamp aux bords de l'image
    src_x = max(0, min(src_x, img_originale.shape[1] - 1))
    src_y = max(0, min(src_y, img_originale.shape[0] - 1))
    src_w = max(1, min(src_w, img_originale.shape[1] - src_x))
    src_h = max(1, min(src_h, img_originale.shape[0] - src_y))

    # crop + resize vers W×H
    crop = img_originale[src_y:src_y+src_h, src_x:src_x+src_w]
    resized = cv2.resize(crop, (W, H), interpolation=cv2.INTER_LINEAR)
    img_data = resized.flatten().astype(np.float32) / 255.0

    if texture_tag and dpg.does_item_exist(texture_tag):
        dpg.delete_item(texture_tag)
    with dpg.texture_registry():
        texture_tag = dpg.add_static_texture(W, H, img_data)

